node n1 {
    type router
    model router
    network-config {
	hostname CENTRAL
	!
	interface eth3
	 ipv6 address 2001:3::2/64
	 ip address 181.29.192.10/30
	!
	interface eth1
	 ipv6 address 2001:1::2/64
	 ip address 181.29.192.2/30
	!
	interface eth2
	 ip address 181.29.192.18/30
	!
	interface eth0
	 ip address 163.10.11.2/30
	!
	interface eth4
	 ip address 10.0.0.1/24
	 ipv6 address 2001:0::1/64
	!
    }
    canvas c1
    iconcoords {699.3333333333334 158.0}
    labelcoords {744.3333333333334 238.0}
    interface-peer {eth0 n2}
    interface-peer {eth2 n4}
    interface-peer {eth4 n11}
    services {NAT IPForward StaticRoute}
    interface-peer {eth1 n7}
    interface-peer {eth3 n3}
    custom-config {
	custom-config-id service:NAT
	custom-command NAT
	config {
	files=('nat.sh', )
	}
    }
    custom-config {
	custom-config-id service:NAT:nat.sh
	custom-command nat.sh
	config {
	#!/bin/sh
	iptables -t nat -A POSTROUTING -s 10.0.0.0/24 -o eth0 -j MASQUERADE
	iptables -A FORWARD -i eth4 -o eth0 -s 10.0.0.0/24 -j ACCEPT
	iptables -A FORWARD -i eth0 -o eth4 -d 10.0.0.0/24 -j ACCEPT
	
	}
    }
    custom-config {
	custom-config-id service:StaticRoute
	custom-command StaticRoute
	config {
	files=('staticroute.sh', )
	}
    }
    custom-config {
	custom-config-id service:StaticRoute:staticroute.sh
	custom-command staticroute.sh
	config {
	#!/bin/sh
	### TABLA DE RUTEO ###
	# RED A
	/sbin/ip route add 181.29.188.0/24 via 181.29.192.9 metric 0
	/sbin/ip route add 181.29.188.0/24 via 181.29.192.17 metric 10
	/sbin/ip route add 181.29.188.0/24 via 181.29.192.1 metric 20
	# RED B
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.17 metric 0
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.9 metric 10
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.1 metric 20
	# RED C
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.17 metric 0
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.9 metric 10
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.1 metric 20
	# RED D
	/sbin/ip route add 181.29.189.128/25 via 181.29.192.1 metric 0
	/sbin/ip route add 181.29.189.128/25 via 181.29.192.9 metric 10
	/sbin/ip route add 181.29.189.128/25 via 181.29.192.17 metric 20
	
	}
    }
}

node n2 {
    type router
    model router
    network-config {
	hostname ISP
	!
	interface eth0
	 ip address 163.10.11.1/30
	!
    }
    canvas c1
    iconcoords {700.3333333333334 35.333333333333336}
    labelcoords {699.3333333333334 19.333333333333332}
    interface-peer {eth0 n1}
    services {DefaultRoute IPForward}
    custom-config {
	custom-config-id service:StaticRoute
	custom-command StaticRoute
	config {
	files=('staticroute.sh', )
	}
    }
    custom-config {
	custom-config-id service:StaticRoute:staticroute.sh
	custom-command staticroute.sh
	config {
	#!/bin/sh
	
	}
    }
    custom-config {
	custom-config-id service:DefaultRoute
	custom-command DefaultRoute
	config {
	files=('defaultroute.sh', )
	}
    }
    custom-config {
	custom-config-id service:DefaultRoute:defaultroute.sh
	custom-command defaultroute.sh
	config {
	#!/bin/sh
	# auto-generated by DefaultRoute service (utility.py)
	ip route add default via 163.10.11.2
	
	}
    }
}

node n3 {
    type router
    model router
    network-config {
	hostname HIDRAULICA
	!
	interface eth1
	 ipv6 address 2001:3::1/64
	 ip address 181.29.192.9/30
	!
	interface eth0
	 ipv6 address 2001:2::1/64
	 ip address 181.29.192.13/30
	!
	interface eth3
	 ip address 181.29.192.6/30
	!
	interface eth2
	 ip address 181.29.188.1/24
	!
    }
    canvas c1
    iconcoords {340.3333333333333 399.3333333333333}
    labelcoords {225.66666666666666 406.6666666666667}
    interface-peer {eth2 n6}
    interface-peer {eth3 n7}
    services {IPForward StaticRoute}
    interface-peer {eth0 n4}
    interface-peer {eth1 n1}
    custom-config {
	custom-config-id service:StaticRoute
