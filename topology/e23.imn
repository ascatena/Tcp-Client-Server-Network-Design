node n7 {
    type router
    model router
    network-config {
	hostname AEROESPACIAL
	!
	interface eth0
	 ipv6 address 2001:1::1/64
	 ip address 181.29.192.1/30
	!
	interface eth1
	 ip address 181.29.192.5/30
	!
	interface eth2
	 ip address 181.29.189.129/25
	!
    }
    canvas c1
    iconcoords {338.6666666666667 159.0}
    labelcoords {349.6666666666667 122.0}
    interface-peer {eth1 n3}
    interface-peer {eth2 n10}
    services {IPForward StaticRoute}
    interface-peer {eth0 n1}
    custom-config {
	custom-config-id service:StaticRoute
	custom-command StaticRoute
	config {
	files=('staticroute.sh', 'AEROESPACIAL.sh', )
	}
    }
    custom-config {
	custom-config-id service:StaticRoute:AEROESPACIAL.sh
	custom-command AEROESPACIAL.sh
	config {
	#!/bin/sh
	# auto-generated by StaticRoute service (utility.py)
	#
	# NOTE: this service must be customized to be of any use
	#       Below are samples that you can uncomment and edit.
	#
	#/sbin/ip route add 10.9.8.0/24 via 10.0.2.1
	#/sbin/ip route add 3ffe:4::/64 via 2001:1::1
	#/sbin/ip route add 10.9.8.0/24 via 10.0.1.1
	#/sbin/ip route add 10.9.8.0/24 via 181.29.189.129
	/sbin/ip route add 181.29.188.0/24 via 10.0.1.2
	
	}
    }
    custom-config {
	custom-config-id service:StaticRoute:staticroute.sh
	custom-command staticroute.sh
	config {
	#!/bin/sh
	### TABLA DE RUTEO ###
	# RED A
	/sbin/ip route add 181.29.188.0/24 via 181.29.192.6 metric 0
	/sbin/ip route add 181.29.188.0/24 via 181.29.192.2 metric 10
	# RED B
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.2 metric 0
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.6 metric 10
	# RED C
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.2 metric 0
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.6 metric 10
	# ISP
	/sbin/ip route add 163.10.11.0/30 via 181.29.192.2 metric 0
	/sbin/ip route add 163.10.11.0/30 via 181.29.192.6 metric 10
	}
    }
}

