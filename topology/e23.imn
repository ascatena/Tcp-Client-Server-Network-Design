	config {
	files=('staticroute.sh', )
	}
    }
    custom-config {
	custom-config-id service:StaticRoute:staticroute.sh
	custom-command staticroute.sh
	config {
	#!/bin/sh
	### TABLA DE RUTEO ###
	#RED B
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.14 metric 0
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.10 metric 10
	/sbin/ip route add 181.29.190.0/23 via 181.29.192.5 metric 20
	# RED C
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.14 metric 0
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.10 metric 10
	/sbin/ip route add 181.29.189.0/26 via 181.29.192.5 metric 20
	# RED D
	/sbin/ip route add 181.29.189.128/25 via 181.29.192.5 metric 0
	/sbin/ip route add 181.29.189.128/25 via 181.29.192.10 metric 10
	/sbin/ip route add 181.29.189.128/25 via 181.29.192.14 metric 20
	# ISP 
	/sbin/ip route add 163.10.11.0/30 via 181.29.192.10 metric 0
	/sbin/ip route add 163.10.11.0/30 via 181.29.192.14 metric 10
	/sbin/ip route add 163.10.11.0/30 via 181.29.192.5 metric 20
	}
    }
}

